# ── Environment ──────────────────────────────────────────────────────────────
# Selects configs/{ENV}.yaml overlay. Options: dev | test | prod
ENV=dev

# ── Twitter (twitterapi.io) ───────────────────────────────────────────────────
# Add MY_API_KEY_2, MY_API_KEY_3, … for multi-key rotation on credit exhaustion
MY_API_KEY_1=your_twitterapi_key

# Search query used by the Twitter ingestion DAG. Overrides the default brand list.
TWITTER_QUERY=

# ── YouTube ───────────────────────────────────────────────────────────────────
YOUTUBE_API_KEY=your_youtube_data_api_v3_key

# Target video to ingest comments from
YOUTUBE_VIDEO_ID=

# ── Google Gemini ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
MODEL=gemini-2.5-flash-lite

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_DEFAULT_REGION=ap-southeast-1

# ── Docker / Spark ────────────────────────────────────────────────────────────
# Absolute path to repo root on the host machine (mounted into Spark containers)
HOST_WORKSPACE=/absolute/path/to/Social_Media_Analysis_Platform

# ── Airflow ───────────────────────────────────────────────────────────────────
AIRFLOW_UID=50000
AIRFLOW_URL=http://localhost:8080
AIRFLOW_USER=admin
AIRFLOW_PASSWORD=admin
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# ── Dashboard (app/) ─────────────────────────────────────────────────────────
# Login credentials for the FastAPI dashboard
USERNAME=admin
PASSWORD=admin

# ── Superset ─────────────────────────────────────────────────────────────────
SUPERSET_URL=http://localhost:8088
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASS=admin

# Comma-separated "dashboard_id:Label" pairs, e.g. "abc123:Overview,def456:Detail"
SUPERSET_DASHBOARDS_TWITTER=
SUPERSET_DASHBOARDS_YOUTUBE=
SUPERSET_DASHBOARDS_FACEBOOK=
